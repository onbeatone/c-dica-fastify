doctype html
html(lang='es')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')

    title Ocus Academy

    link(
      href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css'
      rel='stylesheet'
    )

    link(
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css'
    )

  body.d-flex.flex-column.min-vh-100.bg-light

    // NAVBAR
    nav.navbar.navbar-expand-lg.navbar-dark.bg-primary.shadow-sm
      .container

        a.navbar-brand.fw-bold(href='/')
          i.bi.bi-mortarboard-fill.me-2
          | OCUS

        button.navbar-toggler(
          type='button'
          data-bs-toggle='collapse'
          data-bs-target='#navbarNav'
        )
          span.navbar-toggler-icon

        #navbarNav.collapse.navbar-collapse

          ul.navbar-nav.ms-auto

            li.nav-item
              a.nav-link(href='/')
                i.bi.bi-house-door.me-1
                | Home

            li.nav-item
              a.nav-link(href='/courses')
                i.bi.bi-journal-code.me-1
                | Courses

            if locals.currentUser

              li.nav-item
                a.nav-link(href='/users')
                  i.bi.bi-people.me-1
                  | Users

            // AUTH SECTION
            if locals.currentUser

              li.nav-item.d-flex.align-items-center

                span.nav-link.text-light.me-2
                  i.bi.bi-person-circle.me-1
                  = locals.currentUser.username

                form(
                  method='post'
                  action=route('destroySession')
                )

                  button.btn.btn-sm.btn-danger(type='submit')
                    i.bi.bi-box-arrow-right.me-1
                    | Logout

            else

              li.nav-item
                a.nav-link(href=route('newSession'))
                  i.bi.bi-box-arrow-in-right.me-1
                  | Login

    // CONTENIDO
    main.container.py-5.flex-grow-1

      // FLASH MESSAGES
      //- flash es un objeto { success: [{type, message}], error: [...] }
      //- Aplanamos todos los valores en una sola lista para iterar
      -
        var flashMessages = [];
        if (flash) {
          Object.values(flash).forEach(function(arr) {
            if (Array.isArray(arr)) {
              arr.forEach(function(m) { if (m && m.message) flashMessages.push(m); });
            }
          });
        }

      each msg in flashMessages
        .alert.alert-dismissible.fade.show(
          class=`alert-${msg.type}`
          role='alert'
        )
          i.bi.me-2(
            class=(msg.type === 'success' ? 'bi-check-circle-fill' : msg.type === 'danger' ? 'bi-exclamation-triangle-fill' : 'bi-info-circle-fill')
          )
          = msg.message
          button.btn-close(
            type='button'
            data-bs-dismiss='alert'
            aria-label='Close'
          )

      block content

    // FOOTER
    footer.bg-dark.text-light.mt-auto
      .container.py-5

        .row.g-4

          .col-lg-4
            h5.fw-bold.mb-3
              i.bi.bi-stars.me-2
              | OCUS

            p.text-secondary.mb-0
              | Join Future
            p.small.text-secondary.mt-2
              | Plataforma orientada al aprendizaje tecnológico,
              | desarrollo de software, inteligencia artificial,
              | robótica e innovación digital.

          .col-lg-4
            h5.fw-bold.mb-3
              i.bi.bi-link-45deg.me-2
              | Navigation

            ul.list-unstyled
              li.mb-2
                a.text-decoration-none.text-secondary(href='/')
                  i.bi.bi-house.me-2
                  | Home

              li.mb-2
                a.text-decoration-none.text-secondary(href='/users')
                  i.bi.bi-people.me-2
                  | Users

              li.mb-2
                a.text-decoration-none.text-secondary(href='/courses')
                  i.bi.bi-journal-bookmark.me-2
                  | Courses

          .col-lg-4
            h5.fw-bold.mb-3
              i.bi.bi-share.me-2
              | Connect

            .d-flex.gap-3.fs-4

              a.text-info(
                href='https://github.com/onbeatone'
                target='_blank'
              )
                i.bi.bi-github

        hr.border-secondary.my-4

        .row.align-items-center

          .col-md-6
            p.mb-0.text-secondary.small
              | © 2026 OCUS Corporation

          .col-md-6.text-md-end
            p.mb-0.text-secondary.small
              | Join Future • Learn • Build • Innovate

    script(
      src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js'
    )
