extends ../layouts/page.pug

block content

  .row.justify-content-center

    .col-md-6

      .card.shadow-sm

        .card-header.bg-dark.text-white

          h5.mb-0
            i.bi.bi-pencil-fill.me-2
            | Editar Usuario

        .card-body.p-4

          form(
            method='post'
            action=`/users/${user.id}`
          )
            input(type='hidden' name='_method' value='PATCH')

            .mb-3

              label.form-label(for='name') Nombre

              input.form-control(
                type='text'
                id='name'
                name='name'
                value=user.username
                required
              )

            .mb-3

              label.form-label(for='email') Email

              input.form-control(
                type='email'
                id='email'
                name='email'
                value=user.email
                required
              )

            .d-flex.gap-2.mt-4

              button.btn.btn-primary(type='submit')
                i.bi.bi-check-lg.me-1
                | Guardar cambios

              a.btn.btn-outline-secondary(href=route('user', { id: user.id }))
                | Cancelar
