extends ../layouts/page.pug

block content

  .d-flex.justify-content-between.align-items-center.mb-4

    div
      h1.mb-0
        i.bi.bi-people-fill.me-2.text-primary
        | Users

      p.text-muted.mb-0
        | Manage registered platform users

    a.btn.btn-primary(
      href='/users/new'
    )
      i.bi.bi-person-plus-fill.me-2
      | New User

  if users.length === 0

    .card.shadow.border-0
      .card-body.text-center.py-5

        i.bi.bi-person-x.display-1.text-muted

        h4.mt-3 No users found

        p.text-muted
          | Start by creating your first user.

        a.btn.btn-primary(
          href='/users/new'
        )
          i.bi.bi-person-plus-fill.me-2
          | Create User

  else

    .row.mb-4

      .col-md-4
        .card.border-0.shadow-sm
          .card-body.text-center
            h3.text-primary= users.length
            p.mb-0.text-muted Total Users

      .col-md-4
        .card.border-0.shadow-sm
          .card-body.text-center
            h3.text-danger= users.filter(u => u.role === 'Administrator').length
            p.mb-0.text-muted Administrators

      .col-md-4
        .card.border-0.shadow-sm
          .card-body.text-center
            h3.text-success= users.filter(u => u.role === 'Instructor').length
            p.mb-0.text-muted Instructors

    .card.shadow.border-0

      .card-header.bg-white
        h5.mb-0
          i.bi.bi-list-ul.me-2
          | User Directory

      .card-body.p-0

        .table-responsive

          table.table.table-hover.align-middle.mb-0

            thead.table-light
              tr
                th(style='width:80px') ID
                th User
                th Email
                th Role
                th.text-end Actions

            tbody

              each user in users

                tr

                  td
                    span.badge.bg-secondary= user.id

                  td
                    .d-flex.align-items-center
                      i.bi.bi-person-circle.fs-4.text-primary.me-3
                      div
                        strong.d-block= user.username

                  td
                    div
                        italic.d-block= user.email

                  td
                    if user.role === 'Administrator'
                      span.badge.bg-danger
                        i.bi.bi-shield-lock-fill.me-1
                        | Administrator

                    else if user.role === 'Instructor'
                      span.badge.bg-success
                        i.bi.bi-mortarboard-fill.me-1
                        | Instructor

                    else
                      span.badge.bg-primary
                        i.bi.bi-person-fill.me-1
                        | #{user.role}

                  td.text-end

                    a.btn.btn-sm.btn-outline-primary.me-2(
                      href=`/users/${user.id}`
                    )
                      i.bi.bi-eye-fill.me-1
                      | View

                    a.btn.btn-sm.btn-outline-secondary(
                      href=`/users/${user.id}/edit`
                    )
                      i.bi.bi-pencil-fill.me-1
                      | Edit