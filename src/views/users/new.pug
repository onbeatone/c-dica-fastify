extends ../layouts/page.pug

block content

  .row.justify-content-center
    .col-lg-7.col-xl-6

      .text-center.mb-4
        h1.display-6.fw-bold
          i.bi.bi-person-plus-fill.me-2
          | Create Account

        p.text-muted
          | Join Future

      .card.shadow-lg.border-0

        .card-header.bg-primary.text-white.py-3
          h4.mb-0
            i.bi.bi-shield-lock-fill.me-2
            | User Registration

        .card-body.p-4

          form(action='/users' method='post')

            .mb-3
              label.form-label(for='name')
                i.bi.bi-person.me-2
                | Full Name

              input.form-control(
                id='name'
                type='text'
                name='name'
                placeholder='John Doe'
              )

            .mb-3
              label.form-label(for='email')
                i.bi.bi-envelope.me-2
                | Email

              input.form-control(
                id='email'
                type='email'
                name='email'
                placeholder='john@example.com'
                required
              )

            .mb-3
              label.form-label(for='password')
                i.bi.bi-key.me-2
                | Password

              input.form-control(
                id='password'
                type='password'
                name='password'
                required
              )

            .mb-4
              label.form-label(for='passwordConfirmation')
                i.bi.bi-check-circle.me-2
                | Confirm Password

              input.form-control(
                id='passwordConfirmation'
                type='password'
                name='passwordConfirmation'
                required
              )

            .d-grid
              button.btn.btn-primary.btn-lg(type='submit')
                i.bi.bi-person-check-fill.me-2
                | Register Account

        .card-footer.bg-light.text-center
          small.text-muted
            | OCUS • Join Future