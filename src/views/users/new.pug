extends ../layouts/page.pug

block content

  .row.justify-content-center

    .col-md-6

      .card.shadow-sm

        .card-header.bg-dark.text-white

          h5.mb-0
            i.bi.bi-person-plus-fill.me-2
            | Crear Cuenta

        .card-body.p-4

          //- Errores de validación del schema yup
          if error
            .alert.alert-danger
              i.bi.bi-exclamation-triangle-fill.me-2
              if error.inner && error.inner.length > 0
                ul.mb-0.mt-1
                  each err in error.inner
                    li= err.message
              else
                = error.message

          form(
            method='post'
            action=route('createUser')
          )

            .mb-3

              label.form-label(for='name') Nombre

              input.form-control(
                type='text'
                id='name'
                name='name'
                value=name || ''
                placeholder='Tu nombre completo'
                required
              )

            .mb-3

              label.form-label(for='email') Email

              input.form-control(
                type='email'
                id='email'
                name='email'
                value=email || ''
                placeholder='tu@email.com'
                required
              )

            .mb-3

              label.form-label(for='password') Contraseña

              input.form-control(
                type='password'
                id='password'
                name='password'
                placeholder='Mínimo 5 caracteres'
                required
              )

            .mb-3

              label.form-label(for='passwordConfirmation') Confirmar Contraseña

              input.form-control(
                type='password'
                id='passwordConfirmation'
                name='passwordConfirmation'
                placeholder='Repite tu contraseña'
                required
              )

            .d-grid.mt-4

              button.btn.btn-primary(type='submit')
                i.bi.bi-person-check-fill.me-2
                | Registrarse

          hr

          p.text-center.text-muted.mb-0
            | ¿Ya tienes cuenta?&nbsp;
            a(href=route('newSession')) Inicia sesión
