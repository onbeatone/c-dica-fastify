extends ../layouts/page.pug

block content

  .d-flex.justify-content-between.align-items-center.mb-4

    h2.mb-0
      i.bi.bi-person-circle.me-2.text-primary
      | #{user.username}

    div
      a.btn.btn-outline-secondary.me-2(href=route('editUser', { id: user.id }))
        i.bi.bi-pencil-fill.me-1
        | Editar

      a.btn.btn-outline-secondary(href=route('users'))
        i.bi.bi-arrow-left.me-1
        | Volver

  .card.shadow-sm.border-0

    .card-body.p-4

      .row.mb-3

        .col-md-3.text-muted.fw-semibold ID
        .col-md-9
          span.badge.bg-secondary= user.id

      .row.mb-3

        .col-md-3.text-muted.fw-semibold Nombre
        .col-md-9= user.username

      .row.mb-3

        .col-md-3.text-muted.fw-semibold Email
        .col-md-9= user.email

      .row.mb-3

        .col-md-3.text-muted.fw-semibold Rol
        .col-md-9
          if user.role === 'Administrator'
            span.badge.bg-danger
              i.bi.bi-shield-lock-fill.me-1
              | Administrator
          else if user.role === 'Instructor'
            span.badge.bg-success
              i.bi.bi-mortarboard-fill.me-1
              | Instructor
          else
            span.badge.bg-primary
              i.bi.bi-person-fill.me-1
              | #{user.role}

  //- Eliminar usuario (solo si no es uno mismo)
  if locals.currentUser && locals.currentUser.role === 'Administrator' && locals.currentUser.id !== user.id
    .mt-4

      form(
        method='post'
        action=`/users/${user.id}`
        onsubmit='return confirm("¿Estás seguro de eliminar este usuario?")'
      )
        input(type='hidden' name='_method' value='DELETE')
        button.btn.btn-outline-danger(type='submit')
          i.bi.bi-trash-fill.me-1
          | Eliminar usuario
